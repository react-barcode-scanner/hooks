{
    "name": "@react-barcode-scanner/hooks",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/react-barcode-scanner/hooks.git",
        "directory": "packages/@react-barcode-scanner/hooks"
    },
    "license": "MIT",
    "version": "0.0.73",
    "engines": {
        "node": ">=24"
    },
    "packageManager": "yarn@1.22.22",
    "private": false,
    "main": "dist/index.js",
    "module": "dist/esm/index.js",
    "files": [
        "dist",
        "dist/esm"
    ],
    "types": "dist/index.d.ts",
    "dependencies": {
        "@undecaf/barcode-detector-polyfill": "0.9.23"
    },
    "scripts": {
        "storybook": "storybook dev -p 6006 --https --ssl-cert ./scripts/localhost.crt --ssl-key ./scripts/localhost.key",
        "build-storybook": "storybook build",
        "deploy-storybook": "yarn build-storybook; node scripts/gh-pages-deploy.js",
        "rollup": "rollup -c"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "eslint": {
        "extends": [
            "react-app"
        ],
        "overrides": [
            {
                "files": [
                    "**/*.stories.*"
                ],
                "rules": {
                    "import/no-anonymous-default-export": "off",
                    "@typescript-eslint/no-redeclare": "off"
                }
            }
        ]
    },
    "browserslist": {
        "production": [
            ">1%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@babel/core": "7.29.0",
        "@babel/plugin-syntax-dynamic-import": "7.8.3",
        "@babel/plugin-syntax-flow": "7.28.6",
        "@babel/plugin-transform-react-jsx": "7.28.6",
        "@babel/plugin-transform-runtime": "7.29.0",
        "@babel/preset-env": "7.29.2",
        "@rollup/plugin-commonjs": "29.0.2",
        "@rollup/plugin-node-resolve": "16.0.3",
        "@rollup/plugin-typescript": "12.3.0",
        "@storybook/addon-links": "10.3.3",
        "@storybook/react": "10.3.3",
        "@storybook/react-vite": "10.3.3",
        "@types/node": "25.5.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "autoprefixer": "10.4.27",
        "babel-loader": "10.1.1",
        "babel-plugin-named-exports-order": "0.0.2",
        "gh-pages": "6.3.0",
        "postcss": "8.5.8",
        "prettier": "3.8.1",
        "prop-types": "15.8.1",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "require-from-string": "2.0.2",
        "rollup": "4.60.0",
        "rollup-plugin-dts": "6.4.1",
        "rollup-plugin-exclude-dependencies-from-bundle": "1.1.24",
        "rollup-plugin-postcss": "4.0.2",
        "storybook": "10.3.3",
        "tslib": "2.8.1",
        "typescript": "6.0.2",
        "typescript-plugin-css-modules": "5.2.0",
        "vite": "8.0.3",
        "web-vitals": "5.2.0"
    },
    "peerDependencies": {
        "react": "18 - 19",
        "react-dom": "18 - 19"
    }
}
